@page "/purchases"

<h1>Purchases</h1>

@if(_purchases is null || _purchases.Count == 0) {
<p>No purchases yet :)</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Date</th>
            <th>Location</th>
            <th>Description</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var purchase in _purchases)
        {
            <tr>
                <td>@purchase.PurchaseDateTime.ToString()</td>
                <td>@purchase.Location</td>
                <td>@purchase.Description</td>
            </tr>
        }
        </tbody>
    </table>
}